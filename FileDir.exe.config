<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- generatePublisherEvidence enabled="false" avoids an Authenticode / CRL
       lookup at launch that can stall startup on machines with no network or a
       slow CRL responder. gcConcurrent enabled="true" keeps GC pauses short for
       a responsive UI. -->
  <runtime>
    <generatePublisherEvidence enabled="false" />
    <gcConcurrent enabled="true" />
  </runtime>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
</configuration>
