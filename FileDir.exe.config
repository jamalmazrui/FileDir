<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>

  <runtime>

    <!--
      generatePublisherEvidence=false is the single biggest launch-time win.  Left on
      (the default), the CLR gathers Authenticode publisher evidence at startup, which
      can trigger a certificate-revocation check.  With no network, slow DNS, or a
      captive-portal Wi-Fi, that check BLOCKS until it times out -- seconds of delay
      before the window appears, varying from launch to launch.  These apps do not use
      publisher-evidence security policy, so turning it off is free.
    -->
    <generatePublisherEvidence enabled="false" />

    <!-- Background GC: keeps collection pauses off the UI thread. -->
    <gcConcurrent enabled="true" />

    <!--
      Do NOT add an <assemblyBinding> or <probing> element here.  Windows validates
      this file while building the process activation context, and an empty
      privatePath is invalid -- the program then fails to START with "side-by-side
      configuration is incorrect" (CreateProcess error 14001).  Everything these
      apps load sits beside the executable; no probing element is needed.
      Also: this file must be saved WITHOUT a byte-order mark, for the same reason.
    -->

  </runtime>

</configuration>
